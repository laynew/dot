#!/bin/bash

for bat in $(ls -d /sys/class/power_supply/BAT*); do

    bat_name=$(basename $bat)

    level=$(cat $bat/capacity)
    state=$(upower -i /org/freedesktop/UPower/devices/battery_${bat_name} | grep state | awk '{print $2}')

    if [[ $state == "charging" || $state == "fully-charged" ]]; then
        printf "🔌"
    elif [[ $level -gt 20 ]]; then
        printf "🔋"
    else
        printf "🪫";
    fi

printf " $level%%"
done

